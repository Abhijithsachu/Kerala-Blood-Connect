NODE_ENV=development
PORT=5000

# Local MongoDB / MongoDB Compass
MONGO_URI=mongodb://127.0.0.1:27017/Blood_Donation

# MongoDB Atlas example
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/kerala-blood-connect

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated frontend origins for local + deployed clients.
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
BLOOD_BANK_MAX_LIMIT=50
